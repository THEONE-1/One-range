<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.one.range.dao.AdminDao">
<!--    //注意命名空间就是框架绑定的依据哈-->

    <sql id="base_table">
        users
--         //这是定义了一个属性,方便重复利用罢了
    </sql>
    <select id="login" resultType="com.one.range.model.Admin">
        select * from
        <include refid="base_table" />
        where username=#{username,jdbcType=VARCHAR}
--         //这就是简单的上个参数和在数据库里的类型,会自动调成实体类能接受的类型
        and
        password=#{password,jdbcType=VARCHAR}
    </select>
<!--    //这就是核心部分了,id是说和抽象层哪一个方法绑定,返回值把实体类拉进来自动去绑,而且会根据数据库和实体类自动调整哦.-->

    <select id="getAllInfo" resultType="com.one.range.model.Admin">
        select * from
        <include refid="base_table" />
    </select>

    <select id="getInfoByUserName" resultType="com.one.range.model.Admin">
        select * from
        <include refid="base_table" />
        where username=#{username,jdbcType=VARCHAR}
    </select>

    <update id="updatePWD">
        update
        <include refid="base_table" />
        set password=#{newPWD,jdbcType=VARCHAR}
        where username=#{username,jdbcType=VARCHAR}
    </update>

    <!-- 用户注册 -->
    <insert id="register">
        INSERT INTO
        <include refid="base_table" />
        (username, password, role)
        VALUES (#{username,jdbcType=VARCHAR}, #{password,jdbcType=VARCHAR}, 'user')
    </insert>

    <!-- 检查用户名是否存在 -->
    <select id="checkUsernameExists" resultType="int">
        SELECT COUNT(*) FROM
        <include refid="base_table" />
        WHERE username=#{username,jdbcType=VARCHAR}
    </select>

    <!-- 根据ID获取用户信息 -->
    <select id="getInfoById" resultType="com.one.range.model.Admin">
        SELECT * FROM
        <include refid="base_table" />
        WHERE id=#{id,jdbcType=INTEGER}
    </select>

    <!-- 删除用户 -->
    <delete id="deleteUser">
        DELETE FROM
        <include refid="base_table" />
        WHERE id=#{id,jdbcType=INTEGER}
    </delete>
</mapper>